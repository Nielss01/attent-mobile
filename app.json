{
  "expo": {
    "name": "Attent",
    "slug": "attent",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/attent_app_icon.png",
    "scheme": "attent",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.attent.app",
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "Attent uses Face ID to securely unlock the app."
      }
    },
    "android": {
      "package": "com.attent.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/attent_app_icon.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/attent_app_icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Attent uses Face ID to securely unlock the app."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/attent_app_icon.png",
          "color": "#0a7ea4"
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/01241686-0208-4dc2-9f5c-6f097f0801ab"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "01241686-0208-4dc2-9f5c-6f097f0801ab"
      }
    },
    "owner": "attent-app"
  }
}
